# Copy this file to `server/.env` and fill in your own values.
# `server/.env` is git-ignored and must NEVER be committed (it holds secrets).
#
#   cp server/.env.example server/.env

# Storage driver: "json" (local file, default) or "mongo".
STORAGE_DRIVER=json

# ── MongoDB (only required when STORAGE_DRIVER=mongo) ────────────────────────
# Atlas SRV connection string. Do NOT commit real credentials.
# Example: mongodb+srv://USER:PASSWORD@CLUSTER.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=APP
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=rr_physique_tracker

# API port (client dev server proxies /api here).
PORT=4000

# ── HTTP Basic Auth (optional) ───────────────────────────────────────────────
# Set BOTH to require a username/password before the app loads (recommended for
# public deployments). Leave both unset locally to keep the app open.
AUTH_USER=navin
AUTH_PASS=change-me
